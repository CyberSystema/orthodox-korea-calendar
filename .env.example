# Orthodox Korea Calendar — webapp environment variables
# Copy this file to .env.local and fill in values for local development.
# Production values should be set in Cloudflare Pages → Settings → Environment Variables.

# ── Backend selection ────────────────────────────────────────────────────────
# Option A: explicit URL override (highest priority).
# VITE_BACKEND_BASE_URL=https://orthodox-korea-calendar-backend-staging.leontg.workers.dev

# Option B: pick a known environment ("production" | "staging"). Default: production.
# VITE_BACKEND_ENV=staging

# ── Firebase Cloud Messaging (optional client overrides) ─────────────────────
# These are normally fetched from the backend at /config/client. Override only
# when you need to test against a non-default Firebase project.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=

# ── Legacy OneSignal (deprecated, retained only for the legacy widget flow) ──
# VITE_ONESIGNAL_APP_ID=
